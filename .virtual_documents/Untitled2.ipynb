# 1. Το Προσχέδιο (Class)
class User:
    
    # 2. Η μαγική συνάρτηση κατασκευής (__init__)
    # Τρέχει αυτόματα κάθε φορά που φτιάχνουμε έναν νέο χρήστη
    def __init__(self, first_name, last_name):
        # Αυτά είναι τα Χαρακτηριστικά (Attributes)
        self.first_name = first_name
        self.last_name = last_name
        self.is_active = True  # Προεπιλογή: Κάθε νέος χρήστης είναι ενεργός
        
    # 3. Μια Συμπεριφορά (Method)
    def introduce(self):
        print(f"Γεια σας, είμαι ο/η {self.first_name} {self.last_name}!")
        
    def deactivate_account(self):
        self.is_active = False
        print(f"Ο λογαριασμός του/της {self.first_name} μόλις απενεργοποιήθηκε.")

# ==========================================
# ΠΑΙΖΟΝΤΑΣ ΜΕ ΤΑ ΑΝΤΙΚΕΙΜΕΝΑ (OBJECTS)
# ==========================================

# Φτιάχνουμε δύο διαφορετικά αντικείμενα (χρήστες) από το ίδιο προσχέδιο
user_1 = User("Γιάννης", "Παπαδόπουλος")
user_2 = User("Μαρία", "Γεωργίου")

# Καλούμε τις μεθόδους τους
user_1.introduce()
user_2.introduce()

# Ας κλείσουμε τον λογαριασμό του Γιάννη
user_1.deactivate_account()

# Ελέγχουμε τις ιδιότητές τους (Attributes)
print(f"Ο Γιάννης είναι ενεργός; {user_1.is_active}")
print(f"Η Μαρία είναι ενεργή; {user_2.is_active}")



